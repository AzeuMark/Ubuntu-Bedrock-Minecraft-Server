# Bedrock Panel backend secrets — copy this file to ".env" and fill in real values.
# NEVER commit the real .env file. ".env" is git-ignored.

# A long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# A bcrypt hash of your admin password. Generate one with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 10))" 'yourpassword'
ADMIN_PASSWORD_HASH=$2a$10$replace-with-your-bcrypt-hash

# Port the backend listens on. The single-port app also serves the built React files.
PORT=3000

# Absolute path to the Bedrock server folder on this machine.
BEDROCK_DIR=/root/bedrock-server

# Path to the swap file (must match the sudoers rule installed in Phase 7).
SWAPFILE=/swapfile

# Set to "production" on the VPS. Affects Express behaviors.
NODE_ENV=development
